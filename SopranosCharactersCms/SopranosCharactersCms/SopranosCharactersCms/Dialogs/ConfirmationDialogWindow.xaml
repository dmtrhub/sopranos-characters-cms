<Window x:Class="SopranosCharactersCms.Dialogs.ConfirmationDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="Transparent"
        WindowStartupLocation="Manual"
        Title="ConfirmationDialogWindow">
    <Window.Resources>
        <Style x:Key="ModalButtonStyle" TargetType="Button">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="#66000000">
        <Border Width="500"
                Height="280"
                CornerRadius="12"
                Background="#1F1F1F"
                BorderBrush="#7A1E1E"
                BorderThickness="3"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
            <Canvas>
                <TextBlock x:Name="TitleTextBlock"
                           Canvas.Left="140"
                           Canvas.Top="20"
                           Width="220"
                           Text="Delete Character"
                           FontFamily="Segoe UI"
                           FontWeight="Bold"
                           FontSize="28"
                           Foreground="#F5E6C8"
                           TextAlignment="Center"/>

                <Button x:Name="CloseButton"
                        Canvas.Left="460"
                        Canvas.Top="8"
                        Width="24"
                        Height="24"
                        Style="{StaticResource ModalButtonStyle}"
                        Content="✕"
                        FontFamily="Segoe UI"
                        FontWeight="Bold"
                        FontSize="20"
                        Foreground="#D65C5C"
                        Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="CloseButton_Click"/>

                <TextBlock x:Name="MessageTextBlock"
                           Canvas.Left="40"
                           Canvas.Top="90"
                           Width="460"
                           TextWrapping="Wrap"
                           FontFamily="Segoe UI"
                           FontWeight="Regular"
                           FontSize="14"
                           Foreground="#B8B5AE"
                           Text="Are you sure you want to continue?"/>

                <Border x:Name="CancelBorder"
                        Canvas.Left="50"
                        Canvas.Top="180"
                        Width="180"
                        Height="44"
                        CornerRadius="6"
                        Background="Transparent"
                        BorderBrush="#B08D57"
                        BorderThickness="2">
                    <Button x:Name="CancelButton"
                            Style="{StaticResource ModalButtonStyle}"
                            Background="Transparent"
                            BorderThickness="0"
                            Foreground="#B08D57"
                            FontFamily="Segoe UI"
                            FontWeight="Bold"
                            FontSize="14"
                            Content="Cancel"
                            Cursor="Hand"
                            Click="CancelButton_Click"/>
                </Border>

                <Border x:Name="ConfirmBorder"
                        Canvas.Left="270"
                        Canvas.Top="180"
                        Width="180"
                        Height="44"
                        CornerRadius="6"
                        Background="#D65C5C"
                        BorderBrush="#D65C5C"
                        BorderThickness="1">
                    <Button x:Name="ConfirmButton"
                            Style="{StaticResource ModalButtonStyle}"
                            Background="Transparent"
                            BorderThickness="0"
                            Foreground="#F5E6C8"
                            FontFamily="Segoe UI"
                            FontWeight="Bold"
                            FontSize="14"
                            Content="Delete"
                            Cursor="Hand"
                            Click="ConfirmButton_Click"/>
                </Border>
            </Canvas>
        </Border>
    </Grid>
</Window>
