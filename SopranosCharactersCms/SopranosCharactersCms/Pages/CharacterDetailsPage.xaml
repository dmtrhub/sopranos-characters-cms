<Page x:Class="SopranosCharactersCms.Pages.CharacterDetailsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Title="CharacterDetailsPage">
    <Grid Background="{StaticResource BackgroundMainBrush}">
        <Canvas Width="1920" Height="1080" HorizontalAlignment="Left" VerticalAlignment="Top">
            <Image Canvas.Left="0"
                   Canvas.Top="0"
                   Width="1920"
                   Height="1200"
                   Tag="Images/dashboard.webp"
                   Source="{Binding RelativeSource={RelativeSource Self}, Path=Tag, Converter={StaticResource ImagePathConverter}}"
                   Stretch="UniformToFill"
                   Opacity="0.03"/>

            <TextBlock x:Name="CharacterNameTextBlock"
                       Canvas.Left="40"
                       Canvas.Top="40"
                       FontFamily="Segoe UI"
                       FontWeight="Bold"
                       FontSize="56"
                       Foreground="#B08D57"/>

            <TextBlock x:Name="MetadataTextBlock"
                       Canvas.Left="40"
                       Canvas.Top="115"
                       FontFamily="Segoe UI"
                       FontWeight="Regular"
                       FontSize="12"
                       Foreground="#8B8985"/>

            <Border Canvas.Left="40" Canvas.Top="160" Width="260" Height="400" CornerRadius="6" Background="#2A2A2A" BorderBrush="#4F4F4F" BorderThickness="2">
                <Image x:Name="CharacterImage" Stretch="UniformToFill"/>
            </Border>

            <TextBlock x:Name="RoleStatusTextBlock"
                       Canvas.Left="40"
                       Canvas.Top="580"
                       FontFamily="Segoe UI"
                       FontWeight="Regular"
                       FontSize="12"
                       Foreground="#B8B5AE"/>

            <TextBlock Canvas.Left="360"
                       Canvas.Top="160"
                       Text="Description"
                       FontFamily="Segoe UI"
                       FontWeight="Bold"
                       FontSize="18"
                       Foreground="#F5E6C8"/>

            <TextBlock x:Name="DescriptionTextBlock"
                       Canvas.Left="360"
                       Canvas.Top="200"
                       Width="1500"
                       TextWrapping="Wrap"
                       FontFamily="Segoe UI"
                       FontWeight="Regular"
                       FontSize="14"
                       Foreground="#B8B5AE"/>

            <TextBlock Canvas.Left="360"
                       Canvas.Top="430"
                       FontFamily="Segoe UI"
                       FontWeight="Regular"
                       FontSize="12"
                       Foreground="#C8A96B"
                       TextDecorations="Underline"
                       Cursor="Hand"
                       MouseLeftButtonUp="FullProfileTextBlock_MouseLeftButtonUp"
                       Text="Full Character Profile"/>

            <TextBlock Canvas.Left="360"
                       Canvas.Top="455"
                       Text="Click to open detailed character profile"
                       FontFamily="Segoe UI"
                       FontWeight="Regular"
                       FontSize="11"
                       Foreground="#8B8985"/>

            <Border Canvas.Left="360" Canvas.Top="960" Width="200" Height="48" CornerRadius="6" BorderBrush="{StaticResource GoldPrimaryBrush}" BorderThickness="2" Style="{StaticResource SecondaryActionBorderStyle}">
                <Button x:Name="BackButton"
                        Style="{StaticResource SecondaryActionButtonStyle}"
                        Content="← Back"
                        Click="BackButton_Click"/>
            </Border>

            <Border x:Name="EditButtonBorder" Canvas.Left="570" Canvas.Top="960" Width="200" Height="48" CornerRadius="6" BorderThickness="1" Style="{StaticResource PrimaryActionBorderStyle}">
                <Button x:Name="EditButton"
                        Style="{StaticResource PrimaryActionButtonStyle}"
                        Content="Edit"
                        Click="EditButton_Click"/>
            </Border>
        </Canvas>
    </Grid>
</Page>
