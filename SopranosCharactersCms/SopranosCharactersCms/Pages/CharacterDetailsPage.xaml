<Page x:Class="SopranosCharactersCms.Pages.CharacterDetailsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Title="CharacterDetailsPage">
    <Grid Background="#0A0A0A">
        <Canvas Width="1920" Height="1080" HorizontalAlignment="Left" VerticalAlignment="Top">
            <Image Canvas.Left="0"
                   Canvas.Top="0"
                   Width="1920"
                   Height="1200"
                   Tag="Images/dashboard.webp"
                   Source="{Binding RelativeSource={RelativeSource Self}, Path=Tag, Converter={StaticResource ImagePathConverter}}"
                   Stretch="UniformToFill"
                   Opacity="0.03"/>

            <TextBlock x:Name="CharacterNameTextBlock"
                       Canvas.Left="40"
                       Canvas.Top="40"
                       FontFamily="Segoe UI"
                       FontWeight="Bold"
                       FontSize="56"
                       Foreground="#B08D57"/>

            <TextBlock x:Name="MetadataTextBlock"
                       Canvas.Left="40"
                       Canvas.Top="115"
                       FontFamily="Segoe UI"
                       FontWeight="Regular"
                       FontSize="12"
                       Foreground="#8B8985"/>

            <Border Canvas.Left="40" Canvas.Top="160" Width="200" Height="350" CornerRadius="6" Background="#2A2A2A" BorderBrush="#4F4F4F" BorderThickness="2">
                <Image x:Name="CharacterImage" Stretch="UniformToFill"/>
            </Border>

            <TextBlock x:Name="RoleStatusTextBlock"
                       Canvas.Left="40"
                       Canvas.Top="530"
                       FontFamily="Segoe UI"
                       FontWeight="Regular"
                       FontSize="12"
                       Foreground="#B8B5AE"/>

            <TextBlock Canvas.Left="360"
                       Canvas.Top="160"
                       Text="Description"
                       FontFamily="Segoe UI"
                       FontWeight="Bold"
                       FontSize="18"
                       Foreground="#F5E6C8"/>

            <TextBlock x:Name="DescriptionTextBlock"
                       Canvas.Left="360"
                       Canvas.Top="200"
                       Width="1500"
                       TextWrapping="Wrap"
                       FontFamily="Segoe UI"
                       FontWeight="Regular"
                       FontSize="14"
                       Foreground="#B8B5AE"/>

            <TextBlock Canvas.Left="360"
                       Canvas.Top="430"
                       FontFamily="Segoe UI"
                       FontWeight="Regular"
                       FontSize="12"
                       Foreground="#C8A96B"
                       TextDecorations="Underline"
                       Cursor="Hand"
                       MouseLeftButtonUp="FullProfileTextBlock_MouseLeftButtonUp"
                       Text="Full Character Profile"/>

            <TextBlock Canvas.Left="360"
                       Canvas.Top="455"
                       Text="Click to open detailed character profile"
                       FontFamily="Segoe UI"
                       FontWeight="Regular"
                       FontSize="11"
                       Foreground="#8B8985"/>

            <Border Canvas.Left="360" Canvas.Top="960" Width="200" Height="48" CornerRadius="6" BorderBrush="#B08D57" BorderThickness="2">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="Transparent"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F2C94C"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Button x:Name="BackButton"
                        Style="{StaticResource NoBlueButtonBaseStyle}"
                        Background="Transparent"
                        BorderThickness="0"
                        Foreground="#B08D57"
                        FontFamily="Segoe UI"
                        FontWeight="Bold"
                        FontSize="14"
                        Content="← Back"
                        Cursor="Hand"
                        Click="BackButton_Click"/>
            </Border>

            <Border Canvas.Left="570" Canvas.Top="960" Width="200" Height="48" CornerRadius="6" BorderThickness="1">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="#7A1E1E"/>
                        <Setter Property="BorderBrush" Value="#7A1E1E"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#922626"/>
                                <Setter Property="BorderBrush" Value="#922626"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Button x:Name="EditButton"
                        Style="{StaticResource NoBlueButtonBaseStyle}"
                        Background="Transparent"
                        BorderThickness="0"
                        Foreground="#F5E6C8"
                        FontFamily="Segoe UI"
                        FontWeight="Bold"
                        FontSize="14"
                        Content="Edit"
                        Cursor="Hand"
                        Click="EditButton_Click"/>
            </Border>
        </Canvas>
    </Grid>
</Page>
