<Page x:Class="SopranosCharactersCms.Pages.LoginFigmaPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Title="LoginFigmaPage">
    <Page.Resources>
        <Style x:Key="SquareCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="Box" Width="24" Height="24" Background="Transparent" BorderBrush="#4F4F4F" BorderThickness="2" CornerRadius="2">
                            <Viewbox Width="12" Height="12" HorizontalAlignment="Center" VerticalAlignment="Center" Stretch="Uniform">
                                <Path x:Name="CheckMark"
                                      Data="M2,7 L5,10 L10,3"
                                      Stroke="#F5E6C8"
                                      StrokeThickness="2"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round"
                                      Visibility="Collapsed"/>
                            </Viewbox>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Box" Property="Background" Value="#7A1E1E"/>
                                <Setter TargetName="Box" Property="BorderBrush" Value="#B08D57"/>
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid Background="{StaticResource BackgroundMainBrush}">
        <Canvas Width="1920" Height="1080" HorizontalAlignment="Left" VerticalAlignment="Top">
            <Image Canvas.Left="0"
                   Canvas.Top="0"
                   Width="753"
                   Height="1080"
                   Tag="Images/login.jpg"
                   Source="../Images/login.jpg"
                   Stretch="UniformToFill"
                   Opacity="0.95"/>

            <Rectangle Canvas.Left="753" Canvas.Top="0" Width="1167" Height="1080" Fill="{StaticResource BackgroundMainBrush}"/>

            <TextBlock Canvas.Left="1146"
                       Canvas.Top="133"
                       Text="The Sopranos"
                       Foreground="#B08D57"
                       FontSize="64"
                       FontWeight="Bold"
                       FontFamily="Oswald"/>

            <TextBlock Canvas.Left="1154"
                       Canvas.Top="228"
                       Text="Character Management System"
                       Foreground="#B8B5AE"
                       FontSize="24"
                       FontWeight="Regular"
                       FontFamily="Segoe UI"/>

            <Border Canvas.Left="1080"
                    Canvas.Top="322"
                    Width="500"
                    Height="520"
                    Background="#1F1F1F"
                    CornerRadius="12"
                    BorderBrush="#4F4F4F"
                    BorderThickness="2">
            </Border>

            <TextBlock Canvas.Left="1100" Canvas.Top="352" Text="Username" Foreground="#F5E6C8" FontSize="15" FontWeight="Regular" FontFamily="Segoe UI"/>
            <TextBox Canvas.Left="1100" Canvas.Top="382" Width="440" Height="44" x:Name="UsernameTextBox"
                     Background="#2A2A2A" Foreground="#F5E6C8" BorderBrush="#4F4F4F" BorderThickness="2"
                     FontFamily="Segoe UI" FontSize="14" Padding="12,10,12,10" ToolTip="Enter username"
                     TextChanged="UsernameTextBox_TextChanged"
                     GotFocus="UsernameTextBox_GotFocus"
                     LostFocus="UsernameTextBox_LostFocus"/>
            <TextBlock Canvas.Left="1114" Canvas.Top="394" x:Name="UsernamePlaceholderTextBlock" Text="Enter username" Foreground="#8B8985" FontFamily="Segoe UI" FontSize="14" IsHitTestVisible="False"/>

            <TextBlock Canvas.Left="1100" Canvas.Top="442" Text="Password" Foreground="#F5E6C8" FontSize="15" FontWeight="Regular" FontFamily="Segoe UI"/>
            <PasswordBox Canvas.Left="1100" Canvas.Top="472" Width="440" Height="44" x:Name="PasswordBox"
                         Background="#2A2A2A" Foreground="#F5E6C8" BorderBrush="#4F4F4F" BorderThickness="2"
                         FontFamily="Segoe UI" FontSize="14" Padding="12,10,34,10" ToolTip="Enter password"
                         PasswordChanged="PasswordBox_PasswordChanged"
                         GotFocus="PasswordBox_GotFocus"
                         LostFocus="PasswordBox_LostFocus"/>
            <TextBox Canvas.Left="1100" Canvas.Top="472" Width="440" Height="44" x:Name="PasswordVisibleTextBox" Visibility="Collapsed"
                     Background="#2A2A2A" Foreground="#F5E6C8" BorderBrush="#4F4F4F" BorderThickness="2"
                     FontFamily="Segoe UI" FontSize="14" Padding="12,10,34,10" ToolTip="Enter password"
                     TextChanged="PasswordVisibleTextBox_TextChanged"
                     GotFocus="PasswordVisibleTextBox_GotFocus"
                     LostFocus="PasswordVisibleTextBox_LostFocus"/>
            <TextBlock Canvas.Left="1114" Canvas.Top="484" x:Name="PasswordPlaceholderTextBlock" Text="Enter password" Foreground="#8B8985" FontFamily="Segoe UI" FontSize="14" IsHitTestVisible="False"/>

            <Button Canvas.Left="1508"
                    Canvas.Top="486"
                    Width="16"
                    Height="16"
                    x:Name="TogglePasswordVisibilityButton"
                    Style="{StaticResource NoBlueButtonBaseStyle}"
                    Background="Transparent"
                    BorderBrush="Transparent"
                    BorderThickness="0"
                    Padding="0"
                    Cursor="Hand"
                    ToolTip="Show or hide password"
                    Click="TogglePasswordVisibilityButton_Click">
                <Image x:Name="EyeIconImage"
                           Source="{Binding RelativeSource={RelativeSource Self}, Path=Tag, Converter={StaticResource ImagePathConverter}}"
                           Tag="Images/view.png"
                           Width="16"
                           Height="16"
                           Stretch="Uniform"/>
            </Button>

            <TextBlock Canvas.Left="1100" Canvas.Top="520" x:Name="ErrorMessageTextBlock" Text="" Foreground="#D65C5C" FontFamily="Segoe UI" FontSize="12"/>

            <CheckBox Canvas.Left="1100" Canvas.Top="545" x:Name="RememberMeCheckBox" Width="24" Height="24" Style="{StaticResource SquareCheckBoxStyle}"/>
            <TextBlock Canvas.Left="1132" Canvas.Top="546" Width="91" Text="Remember me" Foreground="#B8B5AE" FontFamily="Segoe UI" FontSize="14"/>

            <Border Canvas.Left="1100" Canvas.Top="597" Width="200" Height="48" CornerRadius="6" BorderThickness="1">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="#7A1E1E"/>
                        <Setter Property="BorderBrush" Value="#7A1E1E"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#922626"/>
                                <Setter Property="BorderBrush" Value="#922626"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Button x:Name="SignInButton"
                        Style="{StaticResource NoBlueButtonBaseStyle}"
                        Background="Transparent"
                        BorderThickness="0"
                        Foreground="#F5E6C8"
                        FontFamily="Segoe UI"
                        FontSize="14"
                        FontWeight="Bold"
                        Content="Sign In"
                        Cursor="Hand"
                        ToolTip="Sign in to the system"
                        Click="SignInButton_Click"/>
            </Border>

            <Border Canvas.Left="1340" Canvas.Top="597" Width="200" Height="48" CornerRadius="6" BorderBrush="#B08D57" BorderThickness="2">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="Transparent"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F2C94C"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Button x:Name="ExitButton" Style="{StaticResource NoBlueButtonBaseStyle}" Background="Transparent" BorderThickness="0" Foreground="#B08D57" Content="Exit" FontFamily="Segoe UI" FontSize="14" FontWeight="Bold" Cursor="Hand" ToolTip="Exit application" Click="ExitButton_Click"/>
            </Border>

            <TextBlock Canvas.Left="1224" Canvas.Top="820" Text="Use predefined Admin or Visitor credentials" Foreground="#8B8985" FontFamily="Segoe UI" FontSize="11"/>
        </Canvas>
    </Grid>
</Page>
