<Page x:Class="SopranosCharactersCms.Pages.CharacterListPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      x:Name="RootPage"
      Title="CharacterListPage">
    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

        <Style x:Key="HeaderTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#F5E6C8"/>
            <Setter Property="FontFamily" Value="{StaticResource BodyFontFamily}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="CharacterNameHyperlinkStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#C8A96B"/>
            <Setter Property="FontFamily" Value="{StaticResource BodyFontFamily}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="TextDecorations" Value="Underline"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="#F2C94C"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ActionHyperlinkStyle" TargetType="TextBlock" BasedOn="{StaticResource CharacterNameHyperlinkStyle}">
            <Setter Property="FontWeight" Value="Regular"/>
        </Style>

        <Style x:Key="HeaderIconStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource IconFontFamily}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#B08D57"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Page.Resources>

    <Grid Background="{StaticResource BackgroundMainBrush}">
        <Canvas Width="1920" Height="1080" HorizontalAlignment="Left" VerticalAlignment="Top">
            <Image Canvas.Left="0"
                   Canvas.Top="0"
                   Width="1920"
                   Height="1200"
                   Tag="Images/dashboard.webp"
                   Source="{Binding RelativeSource={RelativeSource Self}, Path=Tag, Converter={StaticResource ImagePathConverter}}"
                   Stretch="UniformToFill"
                   Opacity="0.03"/>

            <TextBlock Canvas.Left="456"
                       Canvas.Top="24"
                       Text="The Sopranos - Character Management"
                       Foreground="#B08D57"
                       FontFamily="{StaticResource HeadingFontFamily}"
                       FontWeight="Bold"
                       FontSize="64"/>

            <TextBlock Canvas.Left="864"
                       Canvas.Top="110"
                       Text="Admin Dashboard"
                       Foreground="#B8B5AE"
                       FontFamily="Segoe UI"
                       FontWeight="Regular"
                       FontSize="24"
                       Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVisibilityConverter}}"/>

            <Border Canvas.Left="10"
                    Canvas.Top="160"
                    Width="1900"
                    Height="60"
                    CornerRadius="6"
                    Background="#1F1F1F"
                    BorderBrush="#4F4F4F"
                    BorderThickness="1"
                    Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVisibilityConverter}}"/>

            <CheckBox x:Name="SelectAllCheckBox"
                      Canvas.Left="30"
                      Canvas.Top="178"
                      Width="24"
                      Height="24"
                      Style="{StaticResource SquareCheckBoxStyle}"
                      Visibility="{Binding IsSelectionVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                      Checked="SelectAllCheckBox_Checked"
                      Unchecked="SelectAllCheckBox_Unchecked"
                      Cursor="Hand"/>

            <TextBlock Canvas.Left="60"
                       Canvas.Top="180"
                       Text="Select All"
                       Foreground="#F5E6C8"
                       FontFamily="Segoe UI"
                       FontSize="14"
                       Visibility="{Binding IsSelectionVisible, Converter={StaticResource BoolToVisibilityConverter}}"/>

            <Border x:Name="AddButtonBorder"
                    Canvas.Left="1500"
                    Canvas.Top="168"
                    Width="200"
                    Height="44"
                    CornerRadius="6"
                    Style="{StaticResource PrimaryActionBorderStyle}"
                    Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVisibilityConverter}}">
                <Button x:Name="AddButton"
                        Style="{StaticResource PrimaryActionButtonStyle}"
                        Content="+ Add Character"
                        Click="AddButton_Click"/>
            </Border>

            <Border x:Name="DeleteButtonBorder"
                    Canvas.Left="1716"
                    Canvas.Top="168"
                    Width="150"
                    Height="44"
                    CornerRadius="6"
                    Style="{StaticResource DangerActionBorderStyle}"
                    Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVisibilityConverter}}">
                <Button x:Name="DeleteButton"
                        Style="{StaticResource DangerActionButtonStyle}"
                        Content="Delete"
                        Click="DeleteButton_Click"/>
            </Border>

            <Border Canvas.Left="10" Canvas.Top="{Binding HeaderTop}" Width="1900" Height="50" CornerRadius="4" Background="#1A2A2A2A" BorderBrush="#4F4F4F" BorderThickness="1"/>

            <TextBlock Canvas.Left="30"
                       Canvas.Top="{Binding HeaderSelectTop}"
                       Width="14"
                       Height="21"
                       Text="☐"
                       Foreground="#B8B5AE"
                       FontSize="16"
                       Visibility="{Binding IsSelectionVisible, Converter={StaticResource BoolToVisibilityConverter}}"/>

            <TextBlock Canvas.Left="100" Canvas.Top="{Binding HeaderIconTop}" Style="{StaticResource HeaderIconStyle}" Text="{StaticResource IconCharacterGlyph}"/>
            <TextBlock Canvas.Left="124" Canvas.Top="{Binding HeaderTextTop}" Text="Character" Style="{StaticResource HeaderTextStyle}"/>

            <TextBlock Canvas.Left="600" Canvas.Top="{Binding HeaderIconTop}" Style="{StaticResource HeaderIconStyle}" Text="{StaticResource IconRoleGlyph}"/>
            <TextBlock Canvas.Left="622" Canvas.Top="{Binding HeaderTextTop}" Text="Role" Style="{StaticResource HeaderTextStyle}"/>

            <TextBlock Canvas.Left="900" Canvas.Top="{Binding HeaderIconTop}" Style="{StaticResource HeaderIconStyle}" Text="{StaticResource IconImageGlyph}"/>
            <TextBlock Canvas.Left="924" Canvas.Top="{Binding HeaderTextTop}" Text="Image" Style="{StaticResource HeaderTextStyle}"/>

            <TextBlock Canvas.Left="1200" Canvas.Top="{Binding HeaderIconTop}" Style="{StaticResource HeaderIconStyle}" Text="{StaticResource IconAddedGlyph}"/>
            <TextBlock Canvas.Left="1222" Canvas.Top="{Binding HeaderTextTop}" Text="Added" Style="{StaticResource HeaderTextStyle}"/>

            <TextBlock Canvas.Left="1550" Canvas.Top="{Binding HeaderIconTop}" Style="{StaticResource HeaderIconStyle}" Text="{StaticResource IconActionsGlyph}"/>
            <TextBlock Canvas.Left="1572" Canvas.Top="{Binding HeaderTextTop}" Text="Actions" Style="{StaticResource HeaderTextStyle}"/>

            <ItemsControl Canvas.Left="10" Canvas.Top="{Binding RowsTop}" Width="1900" ItemsSource="{Binding Characters}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Vertical"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemContainerStyle>
                    <Style TargetType="ContentPresenter">
                        <Setter Property="Margin" Value="0,0,0,10"/>
                    </Style>
                </ItemsControl.ItemContainerStyle>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Width="1900" Height="56" Background="#1F1F1F" BorderBrush="#4F4F4F" BorderThickness="1" Opacity="0">
                            <Border.Triggers>
                                <EventTrigger RoutedEvent="Border.Loaded">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.22"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Border.Triggers>
                            <Canvas>
                                <CheckBox Canvas.Left="20"
                                          Canvas.Top="16"
                                          Width="24"
                                          Height="24"
                                          Style="{StaticResource SquareCheckBoxStyle}"
                                          IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          Visibility="{Binding ElementName=RootPage, Path=IsSelectionVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                                          Cursor="Hand"/>

                                <TextBlock Canvas.Left="90"
                                           Canvas.Top="11"
                                           Text="{Binding FullName}"
                                           Style="{StaticResource CharacterNameHyperlinkStyle}"
                                           ToolTip="Open character (Edit for Admin, Details for Visitor)"
                                           MouseLeftButtonUp="CharacterNameTextBlock_MouseLeftButtonUp"/>

                                <TextBlock Canvas.Left="590"
                                           Canvas.Top="11"
                                           Text="{Binding Role}"
                                           Foreground="#B8B5AE"
                                           FontFamily="Segoe UI"
                                           FontWeight="SemiBold"
                                           FontSize="20"/>

                                <Border Canvas.Left="890" Canvas.Top="4" Width="48" Height="48" Background="#2A2A2A" BorderBrush="#4F4F4F" BorderThickness="1">
                                    <Image Source="{Binding ImagePath, Converter={StaticResource ImagePathConverter}}" Stretch="UniformToFill"/>
                                </Border>

                                <TextBlock Canvas.Left="1190"
                                           Canvas.Top="17"
                                           Text="{Binding DateAddedDisplay}"
                                           Foreground="#FFFFFF"
                                           FontFamily="Segoe UI"
                                           FontWeight="Regular"
                                           FontSize="16"/>

                                <TextBlock Canvas.Left="1538"
                                           Canvas.Top="11"
                                           Style="{StaticResource ActionHyperlinkStyle}"
                                            FontSize="18"
                                           ToolTip="Open details"
                                           MouseLeftButtonUp="ViewTextBlock_MouseLeftButtonUp">
                                    <Run FontFamily="{StaticResource IconFontFamily}" FontSize="14" BaselineAlignment="Center" Text="{StaticResource IconViewGlyph}"/>
                                    <Run Text="  View"/>
                                </TextBlock>
                            </Canvas>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Border Canvas.Left="1700" Canvas.Top="1000" Width="180" Height="44" CornerRadius="6" BorderBrush="{StaticResource GoldPrimaryBrush}" BorderThickness="2" Style="{StaticResource SecondaryActionBorderStyle}">
                <Button x:Name="LogoutButton"
                        Style="{StaticResource SecondaryActionButtonStyle}"
                        Content="Logout"
                        Click="LogoutButton_Click"/>
            </Border>
        </Canvas>
    </Grid>
</Page>
