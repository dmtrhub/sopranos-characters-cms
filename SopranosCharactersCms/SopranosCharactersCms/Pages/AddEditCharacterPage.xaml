<Page x:Class="SopranosCharactersCms.Pages.AddEditCharacterPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Title="AddEditCharacterPage">
    <Page.Resources>
        <DataTemplate x:Key="FontPreviewTemplate">
            <TextBlock Text="{Binding Source}" FontFamily="{Binding}" Foreground="#B8B5AE"/>
        </DataTemplate>

        <DataTemplate x:Key="ColorTemplate">
            <StackPanel Orientation="Horizontal">
                <Rectangle Width="18" Height="18" Fill="{Binding Brush}" Stroke="#4F4F4F" Margin="0,0,8,0"/>
                <TextBlock Text="{Binding Name}" Foreground="#B8B5AE" VerticalAlignment="Center"/>
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="ToolbarColorTemplate">
            <Grid Width="40" Height="40">
                <Rectangle Width="16" Height="16" Fill="{Binding Brush}" Stroke="#4F4F4F" StrokeThickness="1" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>
        </DataTemplate>

        <Style x:Key="ToolbarToggleButtonStyle" TargetType="ToggleButton">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="ToggleBorder" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="ToggleBorder" Property="Background" Value="#557A1E1E"/>
                                <Setter TargetName="ToggleBorder" Property="BorderBrush" Value="#7A1E1E"/>
                                <Setter TargetName="ToggleBorder" Property="BorderThickness" Value="1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ToolbarComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="#2A2A2A"/>
            <Setter Property="Foreground" Value="#B8B5AE"/>
            <Setter Property="BorderBrush" Value="#4F4F4F"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="8,0,0,0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Background" Value="#2A2A2A"/>
                        <Setter Property="Foreground" Value="#B8B5AE"/>
                        <Setter Property="Padding" Value="8,4,8,4"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border x:Name="ItemBorder" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsHighlighted" Value="True">
                                            <Setter TargetName="ItemBorder" Property="Background" Value="#3A3A3A"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="ItemBorder" Property="Background" Value="#444444"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter Property="Background" Value="#3A3A3A"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid Background="#0A0A0A">
        <Canvas Width="1920" Height="1080" HorizontalAlignment="Left" VerticalAlignment="Top">
            <Image Canvas.Left="0"
                   Canvas.Top="0"
                   Width="1920"
                   Height="1200"
                   Tag="Images/dashboard.webp"
                   Source="{Binding RelativeSource={RelativeSource Self}, Path=Tag, Converter={StaticResource ImagePathConverter}}"
                   Stretch="UniformToFill"
                   Opacity="0.03"/>

            <TextBlock x:Name="PageTitleTextBlock"
                       Canvas.Left="740"
                       Canvas.Top="40"
                       Width="460"
                       Text="Add New Character"
                       TextAlignment="Center"
                       FontFamily="Segoe UI"
                       FontWeight="Bold"
                       FontSize="48"
                       Foreground="#B08D57"/>

            <TextBlock Canvas.Left="888"
                       Canvas.Top="100"
                       Text="Fill in all required fields"
                       FontFamily="Segoe UI"
                       FontWeight="Regular"
                       FontSize="14"
                       Foreground="#B8B5AE"/>

            <TextBlock Canvas.Left="40" Canvas.Top="150" Text="Character ID *" FontFamily="Segoe UI" FontWeight="Bold" FontSize="14" Foreground="#F5E6C8"/>
            <TextBox x:Name="IdTextBox"
                     Canvas.Left="40"
                     Canvas.Top="180"
                     Width="350"
                     Height="44"
                     Background="#2A2A2A"
                     Foreground="#F5E6C8"
                     BorderBrush="#4F4F4F"
                     BorderThickness="2"
                     FontFamily="Segoe UI"
                     FontSize="14"
                     Padding="12,10,12,10"
                     TextChanged="IdTextBox_TextChanged"
                     GotFocus="IdTextBox_GotFocus"
                     LostFocus="IdTextBox_LostFocus"/>
            <TextBlock x:Name="IdPlaceholderTextBlock" Canvas.Left="63" Canvas.Top="193" Text="e.g., 1" FontFamily="Segoe UI" FontWeight="Regular" FontSize="12" Foreground="#8B8985" IsHitTestVisible="False"/>
            <TextBlock x:Name="IdErrorTextBlock" Canvas.Left="40" Canvas.Top="228" Text="" FontFamily="Segoe UI" FontWeight="Regular" FontSize="11" Foreground="#D65C5C"/>
            <TextBlock Canvas.Left="320" Canvas.Top="228" Text="(numeric only)" FontFamily="Segoe UI" FontWeight="Regular" FontSize="11" Foreground="#8B8985"/>

            <TextBlock Canvas.Left="40" Canvas.Top="260" Text="Name *" FontFamily="Segoe UI" FontWeight="Bold" FontSize="14" Foreground="#F5E6C8"/>
            <TextBox x:Name="NameTextBox"
                     Canvas.Left="40"
                     Canvas.Top="290"
                     Width="350"
                     Height="44"
                     Background="#2A2A2A"
                     Foreground="#F5E6C8"
                     BorderBrush="#4F4F4F"
                     BorderThickness="2"
                     FontFamily="Segoe UI"
                     FontSize="14"
                     Padding="12,10,12,10"
                     TextChanged="NameTextBox_TextChanged"
                     GotFocus="NameTextBox_GotFocus"
                     LostFocus="NameTextBox_LostFocus"/>
            <TextBlock x:Name="NamePlaceholderTextBlock" Canvas.Left="63" Canvas.Top="303" Text="e.g., Tony Soprano" FontFamily="Segoe UI" FontWeight="Regular" FontSize="12" Foreground="#8B8985" IsHitTestVisible="False"/>
            <TextBlock x:Name="NameErrorTextBlock" Canvas.Left="40" Canvas.Top="338" Text="" FontFamily="Segoe UI" FontWeight="Regular" FontSize="11" Foreground="#D65C5C"/>

            <TextBlock Canvas.Left="40" Canvas.Top="370" Text="Role *" FontFamily="Segoe UI" FontWeight="Bold" FontSize="14" Foreground="#F5E6C8"/>
            <TextBox x:Name="RoleTextBox"
                     Canvas.Left="40"
                     Canvas.Top="400"
                     Width="350"
                     Height="44"
                     Background="#2A2A2A"
                     Foreground="#F5E6C8"
                     BorderBrush="#4F4F4F"
                     BorderThickness="2"
                     FontFamily="Segoe UI"
                     FontSize="14"
                     Padding="12,10,12,10"
                     TextChanged="RoleTextBox_TextChanged"
                     GotFocus="RoleTextBox_GotFocus"
                     LostFocus="RoleTextBox_LostFocus"/>
            <TextBlock x:Name="RolePlaceholderTextBlock" Canvas.Left="63" Canvas.Top="413" Text="e.g., Boss" FontFamily="Segoe UI" FontWeight="Regular" FontSize="12" Foreground="#8B8985" IsHitTestVisible="False"/>
            <TextBlock x:Name="RoleErrorTextBlock" Canvas.Left="40" Canvas.Top="448" Text="" FontFamily="Segoe UI" FontWeight="Regular" FontSize="11" Foreground="#D65C5C"/>

            <TextBlock Canvas.Left="40" Canvas.Top="481" Text="Image *" FontFamily="Segoe UI" FontWeight="Bold" FontSize="14" Foreground="#F5E6C8"/>
            <Border Canvas.Left="40" Canvas.Top="511" Width="150" Height="44" CornerRadius="4" Background="Transparent" BorderBrush="#B08D57" BorderThickness="2">
                <Button x:Name="BrowseImageButton"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Background="Transparent"
                        BorderThickness="0"
                        Foreground="#B08D57"
                        FontFamily="Segoe UI"
                        FontWeight="Regular"
                        FontSize="12"
                        Content="[Browse...]"
                        Cursor="Hand"
                        Click="BrowseImageButton_Click"/>
            </Border>

            <Border Canvas.Left="40" Canvas.Top="571" Width="200" Height="200" CornerRadius="4" Background="#2A2A2A" BorderBrush="#4F4F4F" BorderThickness="2">
                <Image x:Name="ImagePreview" Stretch="UniformToFill"/>
            </Border>
            <TextBlock x:Name="ImagePathTextBlock" Canvas.Left="40" Canvas.Top="778" Text="No image selected" FontFamily="Segoe UI" FontWeight="Regular" FontSize="11" Foreground="#8B8985"/>
            <TextBlock x:Name="ImageErrorTextBlock" Canvas.Left="40" Canvas.Top="794" Text="" FontFamily="Segoe UI" FontWeight="Regular" FontSize="11" Foreground="#D65C5C"/>

            <TextBlock Canvas.Left="40" Canvas.Top="791" Text="Character Description File (RTF) *" FontFamily="Segoe UI" FontWeight="Bold" FontSize="14" Foreground="#F5E6C8"/>
            <Border Canvas.Left="40" Canvas.Top="821" Width="350" Height="44" CornerRadius="4" Background="Transparent" BorderBrush="#B08D57" BorderThickness="2">
                <Button x:Name="BrowseRtfButton"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Content="[Browse...]"
                        Background="Transparent"
                        BorderThickness="0"
                        Foreground="#B08D57"
                        FontFamily="Segoe UI"
                        FontWeight="Regular"
                        FontSize="12"
                        Cursor="Hand"
                        Click="BrowseRtfButton_Click"/>
            </Border>
            <TextBlock x:Name="RtfStatusTextBlock" Canvas.Left="40" Canvas.Top="871" Text="No file selected" FontFamily="Segoe UI" FontWeight="Regular" FontSize="12" Foreground="#8B8985"/>
            <TextBlock x:Name="RtfErrorTextBlock" Canvas.Left="40" Canvas.Top="892" Text="" FontFamily="Segoe UI" FontWeight="Regular" FontSize="11" Foreground="#D65C5C"/>
            <TextBox x:Name="RtfPathTextBox" Visibility="Collapsed"/>

            <Border Canvas.Left="420" Canvas.Top="150" Width="600" Height="50" CornerRadius="4" Background="#1F1F1F" BorderBrush="#4F4F4F" BorderThickness="1"/>

            <Border Canvas.Left="440" Canvas.Top="155" Width="40" Height="40" Background="Transparent" BorderBrush="#4F4F4F" BorderThickness="1"/>
            <ToggleButton x:Name="BoldToggleButton" Canvas.Left="440" Canvas.Top="155" Width="40" Height="40" Style="{StaticResource ToolbarToggleButtonStyle}" Command="EditingCommands.ToggleBold" CommandTarget="{Binding ElementName=DescriptionRichTextBox}" ToolTip="Bold" Cursor="Hand">
                <TextBlock Text="B" FontFamily="Segoe UI" FontWeight="Bold" FontSize="18" Foreground="#B08D57" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </ToggleButton>

            <Border Canvas.Left="490" Canvas.Top="155" Width="40" Height="40" Background="Transparent" BorderBrush="#4F4F4F" BorderThickness="1"/>
            <ToggleButton x:Name="ItalicToggleButton" Canvas.Left="490" Canvas.Top="155" Width="40" Height="40" Style="{StaticResource ToolbarToggleButtonStyle}" Command="EditingCommands.ToggleItalic" CommandTarget="{Binding ElementName=DescriptionRichTextBox}" ToolTip="Italic" Cursor="Hand">
                <TextBlock Text="I" FontFamily="Segoe UI" FontStyle="Italic" FontSize="18" Foreground="#B8B5AE" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </ToggleButton>

            <Border Canvas.Left="540" Canvas.Top="155" Width="40" Height="40" Background="Transparent" BorderBrush="#4F4F4F" BorderThickness="1"/>
            <ToggleButton x:Name="UnderlineToggleButton" Canvas.Left="540" Canvas.Top="155" Width="40" Height="40" Style="{StaticResource ToolbarToggleButtonStyle}" Command="EditingCommands.ToggleUnderline" CommandTarget="{Binding ElementName=DescriptionRichTextBox}" ToolTip="Underline" Cursor="Hand">
                <TextBlock Text="U" FontFamily="Segoe UI" FontSize="18" Foreground="#B8B5AE" TextDecorations="Underline" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </ToggleButton>

            <Rectangle Canvas.Left="590" Canvas.Top="160" Width="2" Height="30" Fill="#4F4F4F"/>

            <ComboBox x:Name="FontFamilyComboBox" Canvas.Left="610" Canvas.Top="155" Width="120" Height="40" Style="{StaticResource ToolbarComboBoxStyle}" ItemTemplate="{StaticResource FontPreviewTemplate}" SelectionChanged="FontFamilyComboBox_SelectionChanged" Cursor="Hand"/>

            <ComboBox x:Name="FontSizeComboBox" Canvas.Left="740" Canvas.Top="155" Width="80" Height="40" Style="{StaticResource ToolbarComboBoxStyle}" SelectionChanged="FontSizeComboBox_SelectionChanged" Cursor="Hand"/>

            <Border Canvas.Left="830" Canvas.Top="155" Width="64" Height="40" Background="#2A2A2A" BorderBrush="#4F4F4F" BorderThickness="1"/>
            <ComboBox x:Name="FontColorComboBox" Canvas.Left="830" Canvas.Top="155" Width="64" Height="40" Style="{StaticResource ToolbarComboBoxStyle}" ItemTemplate="{StaticResource ToolbarColorTemplate}" SelectionChanged="FontColorComboBox_SelectionChanged" Cursor="Hand" Padding="0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center">
                <ComboBox.ToolTip>
                    Font color
                </ComboBox.ToolTip>
            </ComboBox>

            <Border Canvas.Left="420" Canvas.Top="210" Width="600" Height="250" CornerRadius="4" Background="#1F1F1F" BorderBrush="#4F4F4F" BorderThickness="2">
                <RichTextBox x:Name="DescriptionRichTextBox" Width="596" Height="246" FontFamily="Segoe UI" FontSize="14" SelectionChanged="DescriptionRichTextBox_SelectionChanged" TextChanged="DescriptionRichTextBox_TextChanged" GotFocus="DescriptionRichTextBox_GotFocus" LostFocus="DescriptionRichTextBox_LostFocus" Background="Transparent" BorderThickness="0" Foreground="#8B8985" Padding="12,12,12,12" CaretBrush="#B8B5AE" SelectionBrush="#557A1E1E" SelectionOpacity="0.45" FocusVisualStyle="{x:Null}"/>
            </Border>
            <TextBlock x:Name="DescriptionPlaceholderTextBlock" Canvas.Left="435" Canvas.Top="223" Text="Enter character description here..." FontFamily="Segoe UI" FontWeight="Regular" FontSize="14" Foreground="#8B8985" IsHitTestVisible="False"/>

            <TextBlock Canvas.Left="420" Canvas.Top="465" x:Name="WordCountTextBlock" Text="Words: 0" FontFamily="Segoe UI" FontWeight="Regular" FontSize="12" Foreground="#B8B5AE"/>
            <TextBlock x:Name="DescriptionErrorTextBlock" Canvas.Left="420" Canvas.Top="463" Width="600" Text="" TextAlignment="Right" FontFamily="Segoe UI" FontWeight="Regular" FontSize="11" Foreground="#D65C5C"/>

            <Border Canvas.Left="420" Canvas.Top="975" Width="200" Height="48" CornerRadius="6" BorderThickness="1">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="#7A1E1E"/>
                        <Setter Property="BorderBrush" Value="#7A1E1E"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#922626"/>
                                <Setter Property="BorderBrush" Value="#922626"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Button x:Name="SaveButton"
                        Style="{StaticResource NoBlueButtonBaseStyle}"
                        Content="Save"
                        Background="Transparent"
                        BorderThickness="0"
                        Foreground="#F5E6C8"
                        FontFamily="Segoe UI"
                        FontWeight="Bold"
                        FontSize="14"
                        Cursor="Hand"
                        Click="SaveButton_Click"/>
            </Border>

            <Border Canvas.Left="630" Canvas.Top="975" Width="200" Height="48" CornerRadius="6" BorderBrush="#B08D57" BorderThickness="2">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="Transparent"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F2C94C"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Button x:Name="CancelButton"
                        Style="{StaticResource NoBlueButtonBaseStyle}"
                        Content="Cancel"
                        Background="Transparent"
                        BorderThickness="0"
                        Foreground="#B08D57"
                        FontFamily="Segoe UI"
                        FontWeight="Bold"
                        FontSize="14"
                        Cursor="Hand"
                        Click="CancelButton_Click"/>
            </Border>
        </Canvas>
    </Grid>
</Page>
