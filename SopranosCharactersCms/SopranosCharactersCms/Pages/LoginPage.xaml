<Page x:Class="SopranosCharactersCms.Pages.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Title="LoginPage">
    <Grid Background="{StaticResource BackgroundMainBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="340"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#22000000" BorderBrush="#3A3A3A" BorderThickness="0,0,1,0">
            <Grid>
                <Image Tag="Resources/Images/placeholder.png" Source="{Binding RelativeSource={RelativeSource Self}, Path=Tag, Converter={StaticResource ImagePathConverter}}" Stretch="UniformToFill" Opacity="0.85"/>
                <Rectangle Fill="#77000000"/>
                <TextBlock Text="The Sopranos" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,70,0,0" Foreground="White" FontSize="32" FontWeight="Bold"/>
            </Grid>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="120"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="60,24,0,0">
                <TextBlock Text="The Sopranos" Foreground="{StaticResource GoldPrimaryBrush}" FontSize="52" FontWeight="Bold"/>
                <TextBlock Text="Character Management System" Foreground="{StaticResource TextSecondaryBrush}" FontSize="14" Margin="2,6,0,0"/>
            </StackPanel>

            <Border Grid.Row="1" Width="330" Height="420" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="60,20,0,0"
                    Padding="18" Background="#AA1B1B1B" CornerRadius="6" BorderBrush="{StaticResource BorderPrimaryBrush}" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Username" Foreground="{StaticResource TextPrimaryBrush}" FontSize="12"/>
                    <TextBox Grid.Row="1" x:Name="UsernameTextBox" Height="30" Margin="0,4,0,0" FontSize="11"
                             Background="#332A2A2A" Foreground="{StaticResource TextPrimaryBrush}" BorderBrush="{StaticResource BorderPrimaryBrush}" BorderThickness="1"
                             ToolTip="Enter username"/>
                    <TextBlock Grid.Row="2" x:Name="UsernameErrorTextBlock" Foreground="{StaticResource ErrorPrimaryBrush}" FontSize="10" Margin="0,3,0,8"/>

                    <TextBlock Grid.Row="3" Text="Password" Foreground="{StaticResource TextPrimaryBrush}" FontSize="12"/>
                    <PasswordBox Grid.Row="4" x:Name="PasswordBox" Height="30" Margin="0,4,0,0" FontSize="11"
                                 Background="#332A2A2A" Foreground="{StaticResource TextPrimaryBrush}" BorderBrush="{StaticResource BorderPrimaryBrush}" BorderThickness="1"
                                 ToolTip="Enter password"/>
                    <TextBlock Grid.Row="5" x:Name="PasswordErrorTextBlock" Foreground="{StaticResource ErrorPrimaryBrush}" FontSize="10" Margin="0,3,0,8"/>

                    <CheckBox Grid.Row="6" Content="Remember me" Foreground="{StaticResource TextSecondaryBrush}" FontSize="10" Margin="0,2,0,12"/>

                    <StackPanel Grid.Row="7" Orientation="Horizontal">
                        <Button x:Name="SignInButton" Content="Sign In" Width="120" Height="26" FontSize="10" Margin="0,0,10,0"
                                Style="{StaticResource PrimaryButtonStyle}" Cursor="Hand" ToolTip="Sign in to the system"
                                Click="SignInButton_Click"/>
                        <Button x:Name="ExitButton" Content="Exit" Width="120" Height="26" FontSize="10"
                                Style="{StaticResource SecondaryButtonStyle}" Cursor="Hand" ToolTip="Exit application"
                                Click="ExitButton_Click"/>
                    </StackPanel>

                    <TextBlock Grid.Row="9" Text="Use predefined Admin or Visitor credentials" Foreground="#66797979" FontSize="8" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,4"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
