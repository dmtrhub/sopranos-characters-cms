<Application x:Class="SopranosCharactersCms.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:SopranosCharactersCms.Converters"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <converters:RelativeImagePathToBitmapConverter x:Key="ImagePathConverter"/>

        <SolidColorBrush x:Key="BackgroundMainBrush" Color="#0A0A0A"/>
        <SolidColorBrush x:Key="SurfacePrimaryBrush" Color="#1F1F1F"/>
        <SolidColorBrush x:Key="SurfaceSecondaryBrush" Color="#2A2A2A"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#F5E6C8"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#B8B5AE"/>
        <SolidColorBrush x:Key="GoldPrimaryBrush" Color="#B08D57"/>
        <SolidColorBrush x:Key="RedPrimaryBrush" Color="#7A1E1E"/>
        <SolidColorBrush x:Key="DangerPrimaryBrush" Color="#D65C5C"/>
        <SolidColorBrush x:Key="BorderPrimaryBrush" Color="#4F4F4F"/>
        <SolidColorBrush x:Key="ErrorPrimaryBrush" Color="#D65C5C"/>

        <Style x:Key="NoBlueButtonBaseStyle" TargetType="Button">
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="0"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource NoBlueButtonBaseStyle}">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="Background" Value="{StaticResource RedPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource RedPrimaryBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#922626"/>
                    <Setter Property="BorderBrush" Value="#922626"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource NoBlueButtonBaseStyle}">
            <Setter Property="Foreground" Value="{StaticResource GoldPrimaryBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{StaticResource GoldPrimaryBrush}"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F2C94C"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource NoBlueButtonBaseStyle}">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="Background" Value="{StaticResource DangerPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource DangerPrimaryBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#C94A4A"/>
                    <Setter Property="BorderBrush" Value="#C94A4A"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="InputTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource SurfaceSecondaryBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderPrimaryBrush}"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#11000000"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderPrimaryBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="FontSize" Value="10"/>
        </Style>

        <Style x:Key="FormLabelTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style x:Key="ValidationTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource ErrorPrimaryBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
        </Style>

        <Style TargetType="Hyperlink">
            <Setter Property="Foreground" Value="{StaticResource GoldPrimaryBrush}"/>
            <Setter Property="TextDecorations" Value="Underline"/>
        </Style>
    </Application.Resources>
</Application>
